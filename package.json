{
  "name": "daily-timer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,vue,json,css}\"",
    "test": "vitest run --exclude **/*.visual.test.*",
    "test:ci": "vitest run",
    "test:ci:update": "vitest run --update"
  },
  "dependencies": {
    "moment": "^2.30.1",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/browser-playwright": "^4.1.8",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vite-plugin-eslint": "^1.8.1",
    "vitest": "^4.1.0",
    "vitest-browser-vue": "^2.1.0",
    "vue-tsc": "^3.3.3"
  }
}
